MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE_NAME
SECRET=your_jwt_secret_here_make_it_long_and_random
PORT=7000
NODE_ENV=development

# When the live site URL includes a subpath (e.g. https://yourdomain.com/demos/daily-tarot/),
# set APP_BASE to that path with NO trailing slash. Must match the client build (VITE_BASE_PATH).
# Leave empty for local dev at http://localhost:PORT/ only.
APP_BASE=

# Build the client for /demos/daily-tarot/ before FTP (PowerShell), then set APP_BASE=/demos/daily-tarot on the server:
#   cd client
#   $env:VITE_BASE_PATH='/demos/daily-tarot/'; npm run build
